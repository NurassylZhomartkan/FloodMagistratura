# Скопируйте в .env в корне репозитория:  cp deploy.env.example .env

POSTGRES_USER=flood
POSTGRES_PASSWORD=замените_на_случайную_строку
POSTGRES_DB=floodDB

# JWT — обязательно смените в продакшене (длинная случайная строка)
SECRET_KEY=замените_на_длинную_случайную_строку

# Публичный origin браузера для CORS (через запятую). Должен совпадать с тем, как пользователь открывает сайт.
# Примеры: https://floodsite.example.com  или  http://203.0.113.10
CORS_ORIGINS=https://ваш-домен.ru

# Ссылки в письмах (верификация, сброс пароля). Без слэша в конце.
FRONTEND_URL=https://ваш-домен.ru

# Порт HTTP на хосте (внутри compose nginx слушает 80)
HTTP_PORT=80

# Планировщик Selenium для ecodata.kz: в контейнере без Chrome лучше отключить (1)
HYDRO_SCHEDULER_DISABLED=1

# Почта (если пусто — письма не уйдут; см. backend/docs/EMAIL_SETUP.md)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=

# Опционально
# OPENTOPOGRAPHY_API_KEY=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_EARTH_ENGINE_SERVICE_ACCOUNT_JSON=/app/backend/gee-sa.json
